---
import BaseLayout from "../layouts/BaseLayout.astro";
import { awardItems } from "../data/awards.js";

const sortedAwardItems = [...awardItems].sort((a, b) => b.date.localeCompare(a.date));
---

<BaseLayout title="获奖情况 | 周罗义迪个人网站" description="周罗义迪大学阶段获奖情况归档。">
  <main class="content-page">
    <section class="page-heading">
      <h1>获奖情况</h1>
    </section>

    <section class="info-section">
      <div class="section-title-row">
        <h2>大学阶段获奖时间轴</h2>
      </div>

      <div class="award-timeline">
        {sortedAwardItems.map((award) => (
          <article class="award-entry">
            <div class="award-time">
              <time class="award-date-card" datetime={award.date}>{award.dateLabel}</time>
            </div>
            <div class="award-card">
              <div class="award-card-header">
                <h3>{award.title}</h3>
                <a class="evidence-link" href={`/awards/evidence/${award.slug}/`}>佐证材料</a>
              </div>
            </div>
          </article>
        ))}
      </div>
    </section>
  </main>
</BaseLayout>

---
import BaseLayout from "../../../layouts/BaseLayout.astro";
import { getCollection, render } from "astro:content";

export async function getStaticPaths() {
  const paperNotes = (await getCollection("notes"))
    .filter((note) => note.data.category === "paper-note");

  return paperNotes.map((note) => ({
    params: { slug: note.slug.replace(/^papers\//, "") },
    props: { note }
  }));
}

const { note } = Astro.props;
const { Content } = await render(note);
---

<BaseLayout title={`${note.data.title} | 论文笔记`} description={`${note.data.title} 的论文信息与阅读笔记。`}>
  <main class="content-page">
    <article class="paper-note-detail">
      <a class="back-link" href="/notes/">返回个人笔记</a>

      <header class="paper-note-detail-head">
        <div class="paper-note-head">
          <span>{note.data.status}</span>
          <time datetime={note.data.date}>{note.data.date}</time>
        </div>
        <h1>{note.data.title}</h1>
        {note.data.summary && <p>{note.data.summary}</p>}
        <div class="note-tags">
          {note.data.tags.map((tag) => <span>{tag}</span>)}
        </div>
      </header>

      <dl class="paper-note-detail-meta">
        <div>
          <dt>作者</dt>
          <dd>{note.data.authors.join("、")}</dd>
        </div>
        <div>
          <dt>出版时间</dt>
          <dd>{note.data.date}</dd>
        </div>
        <div>
          <dt>发布平台</dt>
          <dd>{note.data.venue}</dd>
        </div>
        {note.data.paperHref && (
          <div>
            <dt>论文获取</dt>
            <dd>
              <a class="paper-link" href={note.data.paperHref} target="_blank" rel="noreferrer">
                论文链接
              </a>
            </dd>
          </div>
        )}
        {note.data.codeHref && (
          <div>
            <dt>开源代码</dt>
            <dd>
              <a class="paper-link" href={note.data.codeHref} target="_blank" rel="noreferrer">
                代码链接
              </a>
            </dd>
          </div>
        )}
      </dl>

      <div class="paper-note-content">
        <Content />
      </div>
    </article>
  </main>
</BaseLayout>

---
import BaseLayout from "../../../layouts/BaseLayout.astro";
import { getCollection } from "astro:content";

const paperNotes = (await getCollection("notes"))
  .filter((note) => note.data.category === "paper-note")
  .sort((a, b) => b.data.date.localeCompare(a.data.date));

const getPaperSlug = (note) => note.slug.replace(/^papers\//, "");
---

<BaseLayout title="论文笔记 | 周罗义迪个人网站" description="周罗义迪的论文阅读笔记数据库。">
  <main class="content-page">
    <section class="page-heading">
      <p>个人笔记 / 论文笔记</p>
      <h1>论文笔记</h1>
      <span>把读过或准备精读的论文整理成卡片数据库，点击后进入论文信息与个人笔记详情。</span>
    </section>

    <section class="info-section">
      <div class="section-title-row">
        <h2>论文数据库</h2>
        <span>{paperNotes.length} 篇</span>
      </div>

      {paperNotes.length > 0 ? (
        <div class="paper-note-list">
          {paperNotes.map((note) => (
            <a class="paper-note-card" href={`/notes/papers/${getPaperSlug(note)}/`}>
              <div class="paper-note-main">
                <div class="paper-note-head">
                  <span>{note.data.status}</span>
                  <time datetime={note.data.date}>{note.data.date}</time>
                </div>
                <h3>{note.data.title}</h3>
                <p>{note.data.summary}</p>
                <div class="note-tags">
                  {note.data.tags.map((tag) => <span>{tag}</span>)}
                </div>
              </div>
              <dl class="paper-note-meta">
                <div>
                  <dt>作者</dt>
                  <dd>{note.data.authors.join("、")}</dd>
                </div>
                <div>
                  <dt>出版时间</dt>
                  <dd>{note.data.date}</dd>
                </div>
                <div>
                  <dt>发布平台</dt>
                  <dd>{note.data.venue}</dd>
                </div>
              </dl>
            </a>
          ))}
        </div>
      ) : (
        <p class="empty-note">暂无论文笔记。</p>
      )}
    </section>
  </main>
</BaseLayout>

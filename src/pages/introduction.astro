---
import BaseLayout from "../layouts/BaseLayout.astro";

const education = [
  {
    stage: "本科",
    school: "山东第一医科大学 - 医学信息与人工智能学院",
    note: "本科教育阶段",
    major: "医学信息工程",
    logo: "/images/schools/shandong-first-medical-university-logo.png"
  },
  {
    stage: "高中",
    school: "广西师范大学附属中学",
    note: "高中教育阶段",
    major: "",
    logo: "/images/schools/high-school-logo.png"
  },
  {
    stage: "初中",
    school: "桂林电子科技大学附属中学",
    note: "初中教育阶段",
    major: "",
    logo: "/images/schools/junior-school-logo.png"
  }
];

const exams = [
  {
    name: "大学英语四级",
    status: "已通过",
    passed: true
  },
  {
    name: "大学英语六级",
    status: "备考中",
    passed: false
  }
];

const profileFacts = [
  ["姓名", "周罗义迪"],
  ["籍贯", "广西桂林市"],
  ["就读学校", "山东第一医科大学 - 医学信息与人工智能学院"],
  ["就读专业", "医学信息工程"],
  ["研究方向", "医学人工智能、医学图像分割、人工智能"],
  ["未来计划", "读研深造"]
];

const researchKeywords = [
  {
    title: "医学人工智能",
    text: "人工智能技术（重点为深度学习）在医学场景中的应用。"
  },
  {
    title: "生物医学图像分割",
    text: "对医学图像进行语义分割，让模型理解每个像素的语义信息。"
  },
  {
    title: "计算机视觉在医学中应用",
    text: "如滤波、配准、对比度增强等算法用于医学图像处理。"
  }
];

const memberships = [
  {
    organization: "山东省人工智能学会",
    role: "学生会员",
    period: "2026-05-11 ~ 2028-08-08"
  }
];
---

<BaseLayout title="个人介绍 | 周罗义迪个人网站" description="周罗义迪的个人基本信息与教育经历。">
  <main class="content-page">
    <section class="page-heading">
      <h1>个人介绍</h1>
    </section>

    <section class="info-section">
      <div class="section-title-row">
        <h2>个人基本信息</h2>
      </div>

      <div class="info-grid">
        <article class="info-box">
          <h3>基础资料</h3>
          <dl class="fact-list">
            {profileFacts.map(([label, value]) => (
              <div>
                <dt>{label}</dt>
                <dd>{value}</dd>
              </div>
            ))}
          </dl>
        </article>

        <article class="info-box">
          <h3>教育经历</h3>
          <ol class="timeline-list">
            {education.map((item) => (
              <li>
                <div class="education-marker">
                  <span>{item.stage}</span>
                  <div class="school-logo-slot">
                    <img src={item.logo} alt={`${item.school} 标志`} />
                  </div>
                </div>
                <div class="education-content">
                  <strong>{item.school}</strong>
                  <p>{item.note}</p>
                  {item.major && <p>就读专业：{item.major}</p>}
                </div>
              </li>
            ))}
          </ol>
        </article>

        <article class="info-box">
          <h3>语言考试</h3>
          <div class="exam-list">
            {exams.map((exam) => (
              <div class="exam-item">
                <span class:list={["status-mark", exam.passed ? "passed" : "pending"]}>
                  {exam.passed ? "✓" : "×"}
                </span>
                <div>
                  <strong>{exam.name}</strong>
                  <p>{exam.status}</p>
                </div>
              </div>
            ))}
          </div>
        </article>

        <article class="info-box">
          <h3>学术组织与会员身份</h3>
          <div class="membership-list">
            {memberships.map((item) => (
              <article class="membership-card">
                <div>
                  <strong>{item.organization}</strong>
                  <p>{item.role}</p>
                </div>
                <span class="date-chip">{item.period}</span>
              </article>
            ))}
          </div>
        </article>
      </div>
    </section>

    <section class="info-section direction-section">
      <div class="section-title-row">
        <h2>学习方向</h2>
      </div>

      <div class="direction-layout">
        <div class="keyword-grid">
          {researchKeywords.map((keyword) => (
            <article class="keyword-card">
              <h3>{keyword.title}</h3>
              <p>{keyword.text}</p>
            </article>
          ))}
        </div>

        <article class="direction-summary">
          <h3>方向说明</h3>
          <p>
            目前的学习重心放在医学人工智能基础与医学图像分割任务上，通过复现模型、观察模型表现、深入理解模型对于不同数据的归纳偏置，
            然后思考有没有可以改进的方向。后续短期内会以深度学习和计算机视觉基础为主要学习方向，结合论文阅读、实验复现和项目实践，
            逐步建立从理论理解到实验验证的完整科研训练路径。
          </p>
        </article>
      </div>
    </section>
  </main>
</BaseLayout>

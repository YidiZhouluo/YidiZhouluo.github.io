---
import BaseLayout from "../layouts/BaseLayout.astro";
import { publicationItems } from "../data/publications.js";

const sortedPublications = [...publicationItems].sort((a, b) => b.date.localeCompare(a.date));
const formalPublications = sortedPublications.filter((item) => item.category === "formal");
const preprintPublications = sortedPublications.filter((item) => item.category !== "formal");
---

<BaseLayout title="论文情况 | 周罗义迪个人网站" description="周罗义迪的期刊、会议论文、预印本与实验报告归档。">
  <main class="content-page">
    <section class="page-heading">
      <h1>论文情况</h1>
    </section>

    <section class="info-section">
      <div class="section-title-row">
        <h2>论文归档</h2>
      </div>

      <div class="publication-rails">
        <section class="publication-rail" aria-labelledby="formal-publications">
          <div class="rail-heading">
            <h3 id="formal-publications">期刊 / 会议论文</h3>
          </div>

          {formalPublications.length > 0 ? (
            <div class="publication-list">
              {formalPublications.map((paper) => (
                <article class="publication-card">
                  <div class="publication-card-head">
                    <h4>{paper.title}</h4>
                    <span>{paper.venue}</span>
                  </div>
                  <dl class="publication-meta">
                    <div>
                      <dt>DOI</dt>
                      <dd>
                        {paper.doi.startsWith("http") ? (
                          <a class="paper-link" href={paper.doi} target="_blank" rel="noreferrer">{paper.doi}</a>
                        ) : (
                          paper.doi
                        )}
                      </dd>
                    </div>
                    <div>
                      <dt>时间</dt>
                      <dd>{paper.dateLabel}</dd>
                    </div>
                  </dl>
                  <div class="paper-link-row">
                    {paper.arxiv && <a class="paper-link" href={paper.arxiv} target="_blank" rel="noreferrer">arXiv 链接</a>}
                    {paper.github && <a class="paper-link" href={paper.github} target="_blank" rel="noreferrer">GitHub 链接</a>}
                  </div>
                </article>
              ))}
            </div>
          ) : (
            <p class="empty-note">暂无期刊或会议论文记录。</p>
          )}
        </section>

        <section class="publication-rail" aria-labelledby="preprint-publications">
          <div class="rail-heading">
            <h3 id="preprint-publications">预印本 / 实验报告</h3>
          </div>

          <div class="publication-list">
            {preprintPublications.map((paper) => (
              <article class="publication-card">
                <div class="publication-card-head">
                  <h4>{paper.title}</h4>
                  <span>{paper.type}</span>
                </div>
                <dl class="publication-meta">
                  <div>
                    <dt>DOI</dt>
                    <dd>
                      {paper.doi.startsWith("http") ? (
                        <a class="paper-link" href={paper.doi} target="_blank" rel="noreferrer">{paper.doi}</a>
                      ) : (
                        paper.doi
                      )}
                    </dd>
                  </div>
                  <div>
                    <dt>时间</dt>
                    <dd>{paper.dateLabel}</dd>
                  </div>
                </dl>
                <div class="paper-link-row">
                  {paper.arxiv && <a class="paper-link" href={paper.arxiv} target="_blank" rel="noreferrer">arXiv 链接</a>}
                  {paper.github && <a class="paper-link" href={paper.github} target="_blank" rel="noreferrer">GitHub 链接</a>}
                </div>
              </article>
            ))}
          </div>
        </section>
      </div>
    </section>
  </main>
</BaseLayout>


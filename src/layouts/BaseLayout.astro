---
import "katex/dist/katex.min.css";
import "../styles/global.css";

const {
  title = "周罗义迪个人网站",
  description = "周罗义迪的个人学术主页。"
} = Astro.props;
---

<!doctype html>
<html lang="zh-CN">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <link rel="icon" href="/images/ico/web_ico.jpg" type="image/jpeg" />
    <script is:inline>
      const storedTheme = localStorage.getItem("site-theme");
      const preferredTheme = window.matchMedia("(prefers-color-scheme: dark)").matches ? "dark" : "light";
      document.documentElement.dataset.theme = storedTheme ?? preferredTheme;
    </script>
    <title>{title}</title>
  </head>
  <body>
    <header class="site-header">
      <a class="brand" href="/">周罗义迪个人网站</a>
      <div class="site-actions">
        <nav class="site-nav" aria-label="主导航">
          <a href="/">主页</a>
          <a href="/introduction/">个人介绍</a>
          <a href="/awards/">获奖情况</a>
          <a href="/publications/">论文情况</a>
          <a href="/notes/">个人笔记</a>
          <a href="/learning/">学习内容</a>
          <a href="/contact/">联系方式</a>
        </nav>
        <div class="theme-menu" data-theme-menu>
          <button
            class="theme-menu-toggle"
            type="button"
            data-theme-menu-toggle
            aria-label="主题设置"
            aria-expanded="false"
          >
            <span aria-hidden="true">⚙</span>
          </button>
          <div class="theme-menu-panel" data-theme-menu-panel hidden>
            <button class="theme-option" type="button" data-theme-option="light">
              <span aria-hidden="true">☀</span>
              <span>白天</span>
            </button>
            <button class="theme-option" type="button" data-theme-option="dark">
              <span aria-hidden="true">☾</span>
              <span>夜晚</span>
            </button>
          </div>
        </div>
      </div>
    </header>

    <slot />

    <footer class="site-footer">
      <p>© 2026 YidiZhouluo. Personal academic archive in progress.</p>
    </footer>

    <script is:inline>
      const themeMenu = document.querySelector("[data-theme-menu]");
      const themeMenuToggle = document.querySelector("[data-theme-menu-toggle]");
      const themeMenuPanel = document.querySelector("[data-theme-menu-panel]");
      const themeOptions = document.querySelectorAll("[data-theme-option]");

      function setTheme(nextTheme) {
        document.documentElement.dataset.theme = nextTheme;
        localStorage.setItem("site-theme", nextTheme);
        syncThemeMenu();
      }

      function syncThemeMenu() {
        const currentTheme = document.documentElement.dataset.theme;
        themeOptions.forEach((option) => {
          option.setAttribute("aria-pressed", String(option.dataset.themeOption === currentTheme));
        });
      }

      function closeThemeMenu() {
        if (!themeMenuPanel || !themeMenuToggle) return;
        themeMenuPanel.hidden = true;
        themeMenuToggle.setAttribute("aria-expanded", "false");
      }

      syncThemeMenu();

      themeMenuToggle?.addEventListener("click", () => {
        if (!themeMenuPanel || !themeMenuToggle) return;
        const shouldOpen = themeMenuPanel.hidden;
        themeMenuPanel.hidden = !shouldOpen;
        themeMenuToggle.setAttribute("aria-expanded", String(shouldOpen));
      });

      themeOptions.forEach((option) => {
        option.addEventListener("click", () => {
          setTheme(option.dataset.themeOption);
          closeThemeMenu();
        });
      });

      document.addEventListener("click", (event) => {
        if (!themeMenu?.contains(event.target)) closeThemeMenu();
      });

      document.addEventListener("keydown", (event) => {
        if (event.key === "Escape") closeThemeMenu();
      });
    </script>
  </body>
</html>
